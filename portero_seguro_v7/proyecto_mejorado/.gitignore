__pycache__/
*.pyc
.secret_key

# Base de datos: normalmente NO se versiona junto al código.
# Si necesitas compartir datos de ejemplo, usa un dump/export aparte,
# nunca el archivo de producción.
*.db
*.db-journal
*.db-wal

# Backups manuales que antes terminaban sueltos en la raíz del proyecto
inventario1.db
*.bak

# Logs de aplicación
logs/

# Respaldos automáticos de la base de datos (no se versionan)
backups/

# Proxy inverso HTTPS (Caddy): binario y datos/certificados locales.
# El binario se descarga solo al lanzar; la CA se regenera por máquina.
caddy.exe
caddy_data/
inventario_porteroseguro_CA.crt

